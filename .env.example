# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Một hoặc nhiều Telegram Chat ID nhận thông báo Pinball.
# Dùng lệnh /id trong bot để lấy ID; nhiều ID ngăn cách bằng dấu phẩy.
ADMIN_CHAT_IDS=123456789,987654321

# Tương thích cấu hình cũ; có thể giữ hoặc bỏ khi đã dùng ADMIN_CHAT_IDS.
ADMIN_CHAT_ID=your_legacy_telegram_chat_id_here

# Pinball Mini App/API base URL
PINBALL_APP_URL=https://pinball.babyress.games

# Web Server Configuration
PORT=3000

# Optional Google Custom Search Configuration
GOOGLE_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CSE_ID=your_google_custom_search_engine_id_here
